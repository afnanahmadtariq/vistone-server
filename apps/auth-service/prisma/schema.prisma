generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/auth-client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth"]
}

// Internal / external classification for organization membership rows.
// Exactly one ORGANIZER per organization is enforced in SQL (partial unique index).
// At most one organization membership per user is enforced with @@unique([userId]).
enum OrganizationMemberKind {
  ORGANIZER
  MANAGER
  CONTRIBUTOR
  CLIENT

  @@schema("auth")
}

// Auth Service Schema - User & Organization Management

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  members     OrganizationMember[]
  roles       Role[]
  
  @@map("organizations")
  @@schema("auth")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  firstName   String?
  lastName    String?
  password    String?
  googleId    String?  @unique
  avatarUrl   String?
  jobTitle    String?
  /// Structured profile for contributors/managers: skill tags + experience entries (AI-friendly JSON).
  professionalProfile Json?
  status      String   @default("active") // active | paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  organizationMemberships OrganizationMember[]
  kycData                 KycData?
  mfaSettings             MfaSetting?
  activityLogs            ActivityLog[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  
  @@map("users")
  @@schema("auth")
}

/// Opaque refresh tokens (stored as SHA-256 hashes). Survives auth-service restarts.
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("auth")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  roleId         String?
  /// Internal taxonomy aligned with Role.name; CLIENT for portal users with Client role.
  memberKind     OrganizationMemberKind @default(CONTRIBUTOR)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId])
  @@map("organization_members")
  @@schema("auth")
}

model Role {
  id             String       @id @default(uuid())
  organizationId String?
  name           String
  permissions    Json
  isSystem       Boolean      @default(false)
  
  organization   Organization? @relation(fields: [organizationId], references: [id])
  members        OrganizationMember[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("roles")
  @@schema("auth")
}

model KycData {
  id          String   @id @default(uuid())
  userId      String   @unique
  status      String
  documents   Json?
  verifiedAt  DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("kyc_data")
  @@schema("auth")
}

model MfaSetting {
  id               String   @id @default(uuid())
  userId           String   @unique
  enabled          Boolean  @default(false)
  secret           String?
  backupCodes      String[]
  verifiedAt       DateTime?
  emailMfaEnabled  Boolean  @default(true)
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mfa_settings")
  @@schema("auth")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
  @@schema("auth")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())

  @@map("activity_logs")
  @@schema("auth")
}

model Invitation {
  id             String   @id @default(uuid())
  email          String
  role           String
  token          String   @unique
  organizationId String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  
  @@map("invitations")
  @@schema("auth")
}
