generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/workforce-client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["workforce"]
}

// Workforce Management Schema - Team & Workforce Management

model Team {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  managerId      String?
  
  members        TeamMember[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("teams")
  @@schema("workforce")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  /// Optional label (e.g. job title). Team manager is always `teams.manager_id`, not a second manager row.
  role      String?
  
  team      Team     @relation(fields: [teamId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@map("team_members")
  @@schema("workforce")
}

model UserSkill {
  id          String   @id @default(uuid())
  userId      String
  skillName   String
  proficiency Int?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_skills")
  @@schema("workforce")
}

model UserAvailability {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  hoursAvailable Int
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_availability")
  @@schema("workforce")
}

/// Per-user workday hours for payroll / reporting (logged by contributor or manager; organizers can view org-wide).
model AttendanceLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  workDate       DateTime @db.Date
  hoursWorked    Decimal  @db.Decimal(6, 2)
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, workDate])
  @@index([organizationId, userId, workDate])
  @@map("attendance_logs")
  @@schema("workforce")
}
