# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/vistone?schema=public"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Cloudflare Turnstile (CAPTCHA)
# Use 1x0000000000000000000000000000000AA for testing (always passes)
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# Service Ports (default values)
AUTH_SERVICE_PORT=3001
WORKFORCE_SERVICE_PORT=3002
PROJECT_SERVICE_PORT=3003
CLIENT_SERVICE_PORT=3004
KNOWLEDGE_SERVICE_PORT=3005
COMMUNICATION_SERVICE_PORT=3006
MONITORING_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
API_GATEWAY_PORT=4000

# Service URLs (for API Gateway)
AUTH_SERVICE_URL=http://localhost:3001
WORKFORCE_SERVICE_URL=http://localhost:3002
PROJECT_SERVICE_URL=http://localhost:3003
CLIENT_SERVICE_URL=http://localhost:3004
KNOWLEDGE_SERVICE_URL=http://localhost:3005
COMMUNICATION_SERVICE_URL=http://localhost:3006
MONITORING_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# Email Configuration (Gmail - for Notification Service)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Frontend URL (for invitation email links)
FRONTEND_URL=https://vistone-app.vercel.app

# MongoDB (Communication Service - Chat Messages)
MONGODB_URI=mongodb://localhost:27017/vistone-chat

# Redis (Socket.IO Pub/Sub Adapter)
REDIS_URL=redis://localhost:6379

# Cloudinary (Videos and Optimized/Compressed Images)
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# Cloudflare R2 (Documents, Raw Files)
CLOUDFLARE_R2_ENDPOINT=https://<your_account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=vistone-media
CLOUDFLARE_R2_PUBLIC_DOMAIN=https://pub-media.vistone.com
